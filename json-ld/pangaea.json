        "documentation": "https://ws.pangaea.de/dds-fdp/",
        "provider": {
          "@id": "https://www.pangaea.de"
        },
        "endpointURL": "https://ws.pangaea.de/dds-fdp/rest/panquery",
        "encodingFormat": "text/tab-separated-values"
      },
      {
        "@type": "WebAPI",
        "@id": "https://ws.pangaea.de/dds-fgp/rest/dwhquery",
