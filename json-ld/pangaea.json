        "documentation": "https://www.pangaea.de/about/services.php",
        "provider": {
          "@id": "https://www.pangaea.de"
        },
        "endpointURL": "https://ws.pangaea.de/oai/provider",
        "encodingFormat": "text/xml",
        "conformsTo": "http://www.openarchives.org/OAI/openarchivesprotocol.html"
      },
      {
        "@type": "WebAPI",
        "@id": "https://ws.pangaea.de/dds-fdp/rest/panquery",
        "name": "PANGAEA Data Download Service - Filter by DOI",
