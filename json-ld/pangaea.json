  "@type": "Organization",
  "@id": "https://www.pangaea.de",
  "name": "PANGAEA",
  "description": "PANGAEA is a data publisher and library for earth and environmental science, providing open access to geoscientific datasets including ocean data, climate records, sediment cores, and environmental measurements from scientific expeditions worldwide.",
  "url": "https://www.pangaea.de/",
  "logo": "https://www.pangaea.de/assets/img/pangaea-logo.png",
  "contactPoint": {
    "@type": "ContactPoint",
    "contactType": "technical support",
    "email": "tech@pangaea.de"
  },
  "sameAs": [
    "https://github.com/pangaea-data-publisher"
  ],
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "PANGAEA Web Services",
    "itemListElement": [
      {
        "@type": "WebAPI",
        "@id": "https://ws.pangaea.de/es/pangaea/panmd/_search",
        "name": "PANGAEA Elasticsearch Search API",
        "description": "Full-text and faceted search across PANGAEA's 445,000+ geoscientific datasets using Elasticsearch.",
        "documentation": "https://wiki.pangaea.de/wiki/PANGAEA_search",
        "provider": {
          "@id": "https://www.pangaea.de"
        },
        "endpointURL": "https://ws.pangaea.de/es/pangaea/panmd/_search",
        "encodingFormat": "application/json"
      },
      {
        "@type": "WebAPI",
        "@id": "https://ws.pangaea.de/oai/provider",
        "name": "PANGAEA OAI-PMH Metadata Harvesting API",
