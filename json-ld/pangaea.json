        "description": "REST service for retrieving geoscientific measurements filtered by geographic bounding box, temporal range, and depth constraints.",
        "documentation": "https://ws.pangaea.de/dds-fgp/",
        "provider": {
          "@id": "https://www.pangaea.de"
        },
        "endpointURL": "https://ws.pangaea.de/dds-fgp/rest/dwhquery",
        "encodingFormat": "text/tab-separated-values"
      },
      {
        "@type": "WebAPI",
        "@id": "https://maps.awi.de/services/common/pangaea_bathymetry/wms",
        "name": "PANGAEA Bathymetry WMS",
        "description": "OGC-compliant Web Map Service providing bathymetric ocean depth map layers.",
        "documentation": "https://www.pangaea.de/tools/",
        "provider": {
          "@id": "https://www.pangaea.de"
        },
        "endpointURL": "https://maps.awi.de/services/common/pangaea_bathymetry/wms",
        "encodingFormat": "image/png",
        "conformsTo": "https://www.ogc.org/standards/wms"
      },
      {
        "@type": "WebAPI",
        "@id": "https://ws.pangaea.de/es/pangaea-terms/term/_search",
        "name": "PANGAEA Term Dictionary API",
        "description": "Elasticsearch-backed REST API for querying PANGAEA's controlled vocabulary and term dictionary.",
        "documentation": "https://ws.pangaea.de/",
        "provider": {
          "@id": "https://www.pangaea.de"
        },
        "endpointURL": "https://ws.pangaea.de/es/pangaea-terms/term/_search",
        "encodingFormat": "application/json"
      }
    ]
